# Supabase (public — safe for browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase (server-only — NEVER use NEXT_PUBLIC_ prefix for these)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Direct PostgreSQL connection for Drizzle ORM
# Use the "URI" tab in Supabase → Project Settings → Database → Connection String
# NOT the pooler URL — pooler breaks drizzle-kit migrations
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project-ref.supabase.co:5432/postgres

# Cron job secret — shared between Vercel Cron and the /api/cron/snapshot route handler
# Add to Vercel Dashboard → Project → Settings → Environment Variables
# Generate with: openssl rand -hex 32
CRON_SECRET=your-random-secret-here

# 크론 잡 대상 유저 UUID (멀티 유저 환경에서 스냅샷을 기록할 단일 사용자)
# Supabase Dashboard → Authentication → Users에서 UUID 확인
# 미설정 시 크론 잡이 스냅샷을 기록하지 않음
CRON_TARGET_USER_ID=your-admin-user-uuid-here

# logo.dev publishable token — used for circular brand logos in the assets table
# Free plan requires attribution link (https://logo.dev)
# Get yours at https://logo.dev → safe to expose in browser (NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_LOGO_DEV_TOKEN=pk_xxxxxxxxxx

# BOK ECOS API key — used for USD/KRW FX rate (primary source)
# Get yours at https://ecos.bok.or.kr/api/ (free registration)
# Falls back to Yahoo Finance if not set or request fails
BOK_API_KEY=your-bok-api-key-here

# 한국투자증권 OpenAPI — KR/US 주식·ETF 현재가 및 OHLC 히스토리에 사용
# 발급: https://apiportal.koreainvestment.com → 앱 등록 → 앱키/앱시크릿 발급
# 토큰은 자동 갱신됨 (24시간 유효, DB에 캐싱)
KIS_APP_KEY=your-kis-app-key-here
KIS_APP_SECRET=your-kis-app-secret-here

# Finnhub API key — 암호화폐 시세에만 사용 (US 주식은 KIS로 교체됨)
# Get yours at https://finnhub.io (free tier available)
FINNHUB_API_KEY=your-finnhub-api-key-here
